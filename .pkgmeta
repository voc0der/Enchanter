package-as: Enchanter

enable-nolib-creation: no

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

ignore:
  - CHANGELOG.md
  - CONTRIBUTING.md
  - LICENSE
  - RELEASING.md
  - README.md
  - TBC_ANNIVERSARY_NOTES.md
  - .github
  - assets
  - tests
  - .gitignore

wowi-archive-previous: no
